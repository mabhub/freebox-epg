# Application Configuration
VITE_APP_TITLE=Freebox EPG

# Freebox API Configuration
# Base URL of the Freebox API (used for dev proxy and image URLs)
# VITE_API_URL=https://your-freebox-host:port/api/latest

# Development Server Configuration
# HTTPS Setup:
# 1. Create ~/https/ directory
# 2. Add key.pem and cert.pem files
# 3. Set VITE_HTTPS=true (default behavior checks for certificates)
# 4. Set to 'false' to explicitly disable HTTPS and suppress warnings
VITE_HTTPS=false
