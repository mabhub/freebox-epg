# Application Configuration
VITE_APP_TITLE=Freebox EPG

# Freebox API Configuration
# Target host for the Vite dev proxy AND for the Netlify build-time
# _redirects generation (scripts/generate-redirects.mjs).
# Never exposed to the client bundle. In production, set this as a
# Netlify site environment variable.
# FREEBOX_API_TARGET=https://your-freebox-host:port

# Development Server Configuration
# HTTPS Setup:
# 1. Create ~/https/ directory
# 2. Add key.pem and cert.pem files
# 3. Set VITE_HTTPS=true (default behavior checks for certificates)
# 4. Set to 'false' to explicitly disable HTTPS and suppress warnings
VITE_HTTPS=false
