# Application Configuration
VITE_APP_TITLE=Vite React MUI Template
# VITE_GITHUB_URL=https://github.com/user/repo

# API Configuration
# VITE_API_URL=http://localhost:3000/api
# VITE_API_TIMEOUT=10000

# Development Server Configuration
# HTTPS Setup:
# 1. Create ~/https/ directory
# 2. Add key.pem and cert.pem files
# 3. Set VITE_HTTPS=true (default behavior checks for certificates)
# 4. Set to 'false' to explicitly disable HTTPS and suppress warnings
VITE_HTTPS=false

# Feature Flags
# VITE_ENABLE_FEATURE_X=true
# VITE_ENABLE_ANALYTICS=false

# Environment
# NODE_ENV is set automatically by Vite (development/production)
# Use import.meta.env.DEV or import.meta.env.PROD in code
